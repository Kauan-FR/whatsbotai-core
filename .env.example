# ═════════════════════════════════════════════════════════════════════════════
# .env.example — Template de variáveis de ambiente do WhatsBotAI
# ═════════════════════════════════════════════════════════════════════════════
#
# Como usar:
#   1. Copie este arquivo para .env: cp .env.example .env
#   2. Preencha os valores correspondentes ao seu ambiente
#   3. NUNCA commite o .env (já está no .gitignore)
#
# Estratégia de profiles:
#   - Cada máquina tem UM .env com as credenciais do ambiente local
#   - Mude os valores conforme onde você está rodando
#   - O profile (dev-docker / dev-local / prod) é definido via --args na execução
#
# ═════════════════════════════════════════════════════════════════════════════

# ─── Database (escolha UMA das três variantes abaixo) ───────────────────────

# Variante 1: dev-docker (Postgres no Docker, em casa)
# DATABASE_URL=jdbc:postgresql://localhost:5432/whatsbotai
# DATABASE_USERNAME=whatsbotai
# DATABASE_PASSWORD=whatsbotai_local_dev

# Variante 2: dev-local (Postgres nativo, no trabalho)
# DATABASE_URL=jdbc:postgresql://localhost:5432/whatsbotai_dev
# DATABASE_USERNAME=postgres
# DATABASE_PASSWORD=<sua-senha-postgres-local>

# Variante 3: prod (Neon — produção)
# DATABASE_URL=jdbc:postgresql://<seu-host>.neon.tech/neondb?sslmode=require
# DATABASE_USERNAME=<usuario-neon>
# DATABASE_PASSWORD=<senha-neon>